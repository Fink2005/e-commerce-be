generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OfferCategory {
  HEAVY
  MEDIUM
  LIGHT
}

enum ProductType {
  PHONE
  PACKAGE
  BUNDLE
  ALL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  name             String?
  password         String
  role             Role          @default(CUSTOMER)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Email confirmation
  isEmailConfirmed Boolean       @default(false)
  emailConfirmToken String?     @unique
  emailConfirmTokenExpiresAt DateTime?

  // Password reset
  resetPasswordToken       String?     @unique
  resetPasswordTokenExpiresAt DateTime?

  // Relations
  orders           Order[]
  refreshTokens    RefreshToken[]
  specialOffers    SpecialOffer[]
  cartItems        CartItem[]
}

model Phone {
  id            Int           @id @default(autoincrement())
  name          String
  brand         String
  price         Float
  rating        Float?
  type         ProductType  @default(PHONE) // Type of the product
  imgUrl        String
  description   String?
  stock         Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  orderItems    OrderItem[]
  specialOffers SpecialOffer[]
  cartItems     CartItem[]
  bundleItems   BundleItem[]
}

model Package {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  price         Float
  rating        Float?
  isActive      Boolean       @default(true)
  type           ProductType  @default(PACKAGE) // Type of the package
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  orderItems    OrderItem[]
  specialOffers SpecialOffer[]
  cartItems     CartItem[]
  bundleItems   BundleItem[]
}

// New model for phone+package bundles
model Bundle {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
imgUrl        String?
  price         Float         // Bundle price (can be less than individual prices)
  rating        Float?
  isActive      Boolean       @default(true)
  type       ProductType  @default(BUNDLE) // Type of the bundle    
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  bundleItems   BundleItem[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  specialOffers SpecialOffer[]
}

// Junction table for bundle contents
model BundleItem {
  id         Int      @id @default(autoincrement())
  bundleId   Int
  phoneId    Int?
  packageId  Int?
  quantity   Int      @default(1)
  
  bundle     Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  phone      Phone?   @relation(fields: [phoneId], references: [id], onDelete: Cascade)
  package    Package? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  @@unique([bundleId, phoneId, packageId])
}

model Order {
  id            Int          @id @default(autoincrement())
  orderNumber   String       @unique
  userId        Int
  totalAmount   Float
  status        OrderStatus  @default(PENDING)
  shippingAddress String?
  billingAddress  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  phoneId     Int?
  packageId   Int?
  bundleId    Int?
  quantity    Int      @default(1)
  unitPrice   Float
  totalPrice  Float
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  phone       Phone?   @relation(fields: [phoneId], references: [id], onDelete: Restrict)
  package     Package? @relation(fields: [packageId], references: [id], onDelete: Restrict)
  bundle      Bundle?  @relation(fields: [bundleId], references: [id], onDelete: Restrict)
}

model CartItem {
  id          Int      @id @default(autoincrement())
  userId      Int
  phoneId     Int?
  packageId   Int?
  bundleId    Int?
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       Phone?   @relation(fields: [phoneId], references: [id], onDelete: Cascade)
  package     Package? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  bundle      Bundle?  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  
  @@unique([userId, phoneId, packageId, bundleId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpecialOffer {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  category    OfferCategory
  discount    Float        // Discount percentage (e.g., 0.2 for 20%)
  userId      Int
  phoneId     Int?
  packageId   Int?
  bundleId    Int?
  isActive    Boolean       @default(true)
  createdAt   DateTime     @default(now())
  expiresAt   DateTime
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       Phone?       @relation(fields: [phoneId], references: [id], onDelete: SetNull)
  package     Package?     @relation(fields: [packageId], references: [id], onDelete: SetNull)
  bundle      Bundle?      @relation(fields: [bundleId], references: [id], onDelete: SetNull)
}